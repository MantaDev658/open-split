#!/usr/bin/env bash
# Full pre-commit gate: build в†’ unit в†’ integration в†’ E2E.
# Install once with: make install-hooks
# Bypass in emergencies: git commit --no-verify

set -euo pipefail

# в”Ђв”Ђ Colours в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RED=$'\033[0;31m'; GRN=$'\033[0;32m'; YLW=$'\033[1;33m'
DIM=$'\033[2m'; NC=$'\033[0m'

# в”Ђв”Ђ State в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
STEP=0; TOTAL=8
STARTED_DB=false; API_PID=""
LOG=$(mktemp); API_LOG=$(mktemp)

cleanup() {
    local code=$?
    rm -f "$LOG" "$API_LOG"
    [ -n "$API_PID" ] && { kill "$API_PID" 2>/dev/null; wait "$API_PID" 2>/dev/null; } || true
    $STARTED_DB && make db-down --no-print-directory 2>/dev/null || true
    exit $code
}
trap cleanup EXIT INT TERM

cd "$(git rev-parse --show-toplevel)"

# в”Ђв”Ђ Millisecond timer (bash 3.2 compatible) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Prefer bash 5+ EPOCHREALTIME; fall back to python3.
now_ms() {
    local rt="${EPOCHREALTIME:-}"
    if [[ -n "$rt" ]]; then
        local r="${rt//./}"; printf '%s' "${r:0:13}"
    else
        python3 -c 'import time; print(int(time.time()*1000))'
    fi
}

# "123ms"  "1.2s"  "12s"  "1m 2s"
fmt_dur() {
    local ms=$1
    if   (( ms < 1000  )); then printf '%dms'      "$ms"
    elif (( ms < 10000 )); then printf '%d.%ds'    "$(( ms/1000 ))" "$(( (ms%1000)/100 ))"
    elif (( ms < 60000 )); then printf '%ds'       "$(( ms/1000 ))"
    else local s=$(( ms/1000 )); printf '%dm %ds'  "$(( s/60 ))" "$(( s%60 ))"
    fi
}

HOOK_START_MS=$(now_ms)

# в”Ђв”Ђ Header в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf "\n${YLW}  Open Split вЂ” pre-commit${NC}\n"
printf "${DIM}  в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}\n\n"

# в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SPIN=('в ‹' 'в ™' 'в №' 'в ё' 'в ј' 'в ґ' 'в ¦' 'в §' 'в ‡' 'в Џ')

show_fail() {
    printf "\n${DIM}  в”Ђв”Ђ output в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}\n"
    sed 's/^/    /' "${1:-$LOG}" | tail -30
    printf "${DIM}  в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}\n\n"
    exit 1
}

# Runs a command in the background, shows a spinner, prints вњ“/вњ— + elapsed.
run_step() {
    local label="$1"; shift
    (( STEP++ )) || true
    local start_ms; start_ms=$(now_ms)
    local si=0

    "$@" >"$LOG" 2>&1 &
    local pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${DIM}%d/%d${NC}  %-34s${YLW}%s${NC}" \
               "$STEP" "$TOTAL" "$label" "${SPIN[$((si % 10))]}"
        sleep 0.1
        (( si++ )) || true
    done
    local rc=0; wait "$pid" || rc=$?
    local dur; dur=$(fmt_dur "$(( $(now_ms) - start_ms ))")

    if [ "$rc" -eq 0 ]; then
        printf "\r  ${DIM}%d/%d${NC}  %-34s${GRN}вњ“${NC}  ${DIM}%s${NC}\n" \
               "$STEP" "$TOTAL" "$label" "$dur"
    else
        printf "\r  ${DIM}%d/%d${NC}  %-34s${RED}вњ—${NC}  ${DIM}%s${NC}\n" \
               "$STEP" "$TOTAL" "$label" "$dur"
        show_fail
    fi
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Code quality
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

run_step "Backend: build & lint"  make check --no-print-directory
run_step "Backend: unit tests"    make test-unit --no-print-directory
run_step "Backend: race detector" make test-race --no-print-directory
run_step "Frontend: install"      make frontend-install --no-print-directory
run_step "Frontend: unit tests"   make frontend-test --no-print-directory
run_step "Frontend: build"        make frontend-build --no-print-directory

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Infrastructure: PostgreSQL
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

printf "\n"
printf "       %-34s" "PostgreSQL"
if nc -z 127.0.0.1 5432 2>/dev/null; then
    make migrate-up --no-print-directory >"$LOG" 2>&1 \
        || { printf "${RED}вњ—${NC}\n"; show_fail; }
    printf "${GRN}вњ“${NC}  ${DIM}running${NC}\n"
else
    make db-up --no-print-directory >"$LOG" 2>&1 \
        || { printf "${RED}вњ—${NC}\n"; show_fail; }
    STARTED_DB=true
    make migrate-up --no-print-directory >"$LOG" 2>&1 \
        || { printf "${RED}вњ—${NC}\n"; show_fail; }
    printf "${GRN}вњ“${NC}  ${DIM}started${NC}\n"
fi

# Integration tests (DB only, no API needed)
run_step "Integration tests"  make test-integration --no-print-directory

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Infrastructure: Backend API (needed for E2E)
# Step 1 (make check) already compiled bin/opensplit-api вЂ” use that
# directly so startup is instant and the process is trivial to kill.
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

printf "       %-34s" "Backend API"

# HTTP health check (not just TCP) to confirm an existing process is actually serving.
api_alive() {
    nc -z 127.0.0.1 8080 2>/dev/null && \
    curl -s --connect-timeout 1 --max-time 2 \
         http://localhost:8080/users -o /dev/null 2>/dev/null
}

if api_alive; then
    printf "${GRN}вњ“${NC}  ${DIM}running${NC}\n"
else
    api_start_ms=$(now_ms)
    si=0
    DATABASE_URL="postgresql://postgres:password@localhost:5432/opensplit?sslmode=disable" \
    JWT_SECRET="pre-commit-hook-secret" \
    ./bin/opensplit-api >"$API_LOG" 2>&1 &
    API_PID=$!
    until nc -z 127.0.0.1 8080 2>/dev/null; do
        printf "\r       %-34s${YLW}%s${NC}" "Backend API" "${SPIN[$((si % 10))]}"
        if ! kill -0 "$API_PID" 2>/dev/null; then
            printf "\r       %-34s${RED}вњ—${NC}\n" "Backend API"
            show_fail "$API_LOG"
        fi
        sleep 0.1; (( si++ )) || true
    done
    printf "\r       %-34s${GRN}вњ“${NC}  ${DIM}%s${NC}\n" \
           "Backend API" "$(fmt_dur "$(( $(now_ms) - api_start_ms ))")"
fi

# Playwright browser (idempotent вЂ” skips download if already installed)
printf "       %-34s" "Playwright browser"
make playwright-install --no-print-directory >"$LOG" 2>&1 \
    || { printf "${RED}вњ—${NC}\n"; show_fail; }
printf "${GRN}вњ“${NC}  ${DIM}ready${NC}\n"
printf "\n"

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# E2E tests
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

run_step "E2E tests (Playwright)"  make frontend-e2e --no-print-directory

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

printf "\n  ${GRN}вњ…  All checks passed${NC}  ${DIM}(%s)${NC}\n\n" \
       "$(fmt_dur "$(( $(now_ms) - HOOK_START_MS ))")"
